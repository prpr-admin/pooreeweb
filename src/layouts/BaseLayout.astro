---
interface Props {
  title?: string;
  fullBleed?: boolean;
}

const { title = '풀이', fullBleed = true } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Information', href: '/information' },
  { label: 'Projects',    href: '/projects' },
  { label: 'Archives',    href: '/archives' },
];
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css"
      rel="stylesheet"
    />
  </head>
  <body class:list={[{ 'full-bleed': fullBleed }]}>

    <header class="header">
      <a href="/" class="logo">
        <img src="/pooreeci.png" alt="풀이" class="logo-img" />
      </a>

      <!-- 데스크톱: 인라인 네비 -->
      <nav class="desktop-nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'dnav-link',
              {
                active:
                  item.href === '/archives'
                    ? currentPath === '/' || currentPath.startsWith('/archives')
                    : currentPath.startsWith(item.href),
              },
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href="https://www.instagram.com/pooree_arc"
          target="_blank"
          rel="noopener noreferrer"
          class="instagram-link"
          aria-label="Instagram"
        >↗</a>
      </nav>

      <!-- 모바일: + 버튼 -->
      <button class="menu-btn" id="menuBtn" aria-label="메뉴" aria-expanded="false">
        <span class="btn-icon">+</span>
      </button>
    </header>

    <!-- 모바일 플로팅 네비 -->
    <nav class="floating-nav" id="floatingNav" aria-hidden="true">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'fnav-link',
            {
              active:
                item.href === '/archives'
                  ? currentPath === '/' || currentPath.startsWith('/archives')
                  : currentPath.startsWith(item.href),
            },
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://www.instagram.com/pooree_arc"
        target="_blank"
        rel="noopener noreferrer"
        class="fnav-link fnav-instagram"
      >Instagram ↗</a>
    </nav>

    <main class="main">
      <slot />
    </main>

  </body>
</html>

<script>
  const menuBtn    = document.getElementById('menuBtn') as HTMLButtonElement;
  const floatingNav = document.getElementById('floatingNav');

  function open() {
    floatingNav?.classList.add('open');
    menuBtn.setAttribute('aria-expanded', 'true');
    floatingNav?.setAttribute('aria-hidden', 'false');
    const icon = menuBtn.querySelector('.btn-icon');
    if (icon) icon.textContent = '×';
  }

  function close() {
    floatingNav?.classList.remove('open');
    menuBtn.setAttribute('aria-expanded', 'false');
    floatingNav?.setAttribute('aria-hidden', 'true');
    const icon = menuBtn.querySelector('.btn-icon');
    if (icon) icon.textContent = '+';
  }

  menuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    floatingNav?.classList.contains('open') ? close() : open();
  });

  document.addEventListener('click', (e) => {
    if (!floatingNav?.contains(e.target as Node) && !menuBtn?.contains(e.target as Node)) {
      close();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --font: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
    --color-text: #1a1a1a;
    --color-text-muted: #1a1a1a;
    --color-text-subtle: #1a1a1a;
    --color-border: rgba(0, 0, 0, 0.1);
    --color-bg: #fff;
    --color-bg-hover: #f8f8f7;
    --header-h: 53px;
  }

  html {
    font-family: var(--font);
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    padding-top: var(--header-h);
  }

  body.full-bleed {
    padding-top: 0;
  }

  a { color: inherit; text-decoration: none; }
</style>

<style>
  /* ── 헤더 ── */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    padding: 0 1.5rem;
    background: transparent;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo { display: flex; align-items: center; }

  .logo-img { height: 24px; width: auto; display: block; }

  /* ── 데스크톱 인라인 네비 ── */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .dnav-link {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: capitalize;
    color: #1a1a1a;
    font-family: var(--font);
    transition: opacity 0.15s;
  }

  .dnav-link:hover { opacity: 0.5; }

  .dnav-link.active { font-weight: 500; }

  .instagram-link {
    font-size: 14px;
    line-height: 1;
    color: #1a1a1a;
    transition: opacity 0.15s;
    display: flex;
    align-items: center;
  }

  .instagram-link:hover { opacity: 0.5; }

  /* ── 모바일 + 버튼 (기본 숨김, 모바일에서 표시) ── */
  .menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    align-items: center;
    padding: 8px 0;
  }

  .btn-icon {
    font-size: 24px;
    font-weight: 300;
    line-height: 1;
    color: #1a1a1a;
    display: block;
    transition: color 0.15s;
    user-select: none;
  }

  .menu-btn:hover .btn-icon { opacity: 0.5; }

  /* ── 모바일 플로팅 네비 패널 ── */
  .floating-nav {
    position: fixed;
    top: var(--header-h);
    right: 1.5rem;
    background: #fff;
    border: 0.5px solid var(--color-border);
    min-width: 180px;
    z-index: 99;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.07);
    display: none;
  }

  .floating-nav.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .fnav-link {
    display: block;
    padding: 0.9rem 1.25rem;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: capitalize;
    color: #1a1a1a;
    border-bottom: 0.5px solid var(--color-border);
    transition: background 0.12s;
    font-family: var(--font);
  }

  .fnav-link:last-child { border-bottom: none; }

  .fnav-link:hover { background: var(--color-bg-hover); }

  .fnav-link.active { font-weight: 500; }

  /* ── 메인 ── */
  .main {
    width: 100%;
    min-height: calc(100vh - var(--header-h));
  }

  /* ── 모바일: + 버튼 표시, 데스크톱 네비 숨김 ── */
  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .menu-btn { display: flex; }
    .floating-nav { display: block; }
    .floating-nav { right: 1rem; min-width: 160px; }
  }
</style>
