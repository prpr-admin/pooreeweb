---
interface Props {
  title?: string;
  fullBleed?: boolean;
}

const { title = '풀이', fullBleed = true } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Information', href: '/information' },
  { label: 'Projects', href: '/projects' },
  { label: 'Archives', href: '/archives' },
];
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css"
      rel="stylesheet"
    />
  </head>
  <body class:list={[{ 'full-bleed': fullBleed }]}>

    <header class="header">
      <a href="/" class="logo">
        <img src="/pooree%20CI_transparent.png" alt="풀이" class="logo-img" />
      </a>

      <nav class="nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'nav-link',
              {
                active:
                  item.href === '/archives'
                    ? currentPath === '/' || currentPath.startsWith('/archives')
                    : currentPath.startsWith(item.href),
              },
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <main class="main">
      <slot />
    </main>

  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --font: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
    --color-text: #1a1a1a;
    --color-text-muted: #888;
    --color-text-subtle: #bbb;
    --color-border: rgba(0, 0, 0, 0.1);
    --color-bg: #fff;
    --color-bg-hover: #f8f8f7;
    --header-h: 44px;
  }

  html {
    font-family: var(--font);
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    padding-top: var(--header-h);
  }

  body.full-bleed {
    padding-top: 0;
  }

  a { color: inherit; text-decoration: none; }
</style>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-h);
    padding: 0 1.5rem;
    background: transparent;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 20px;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link.active {
    color: var(--color-text);
    font-weight: 500;
  }

  .main {
    width: 100%;
    min-height: calc(100vh - var(--header-h));
  }

  @media (max-width: 480px) {
    .nav { gap: 1.25rem; }
    .nav-link { font-size: 9px; letter-spacing: 0.1em; }
  }
</style>
