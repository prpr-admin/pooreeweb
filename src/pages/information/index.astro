---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('information');
const sorted = posts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Information — 풀이">
  <div class="page">
    <ul class="entry-list">
      {sorted.map((post) => (
        <li class="entry-item">
          <a href={`/information/${post.slug}`} class="entry-link">
            <div class="entry-date">
              {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </div>
            <div class="entry-info">
              <span class="entry-title">{post.data.title}</span>
              <p class="entry-desc">{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry-list {
    list-style: none;
  }

  .entry-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .entry-link {
    display: grid;
    grid-template-columns: 90px 1fr;
    align-items: start;
    gap: 1.5rem;
    padding: 1.4rem 1.5rem;
    color: inherit;
    transition: background 0.12s;
  }

  .entry-link:hover {
    background: var(--color-bg-hover);
  }

  .entry-date {
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    padding-top: 0.15rem;
    white-space: nowrap;
  }

  .entry-title {
    font-size: 12px;
    letter-spacing: 0.06em;
    font-weight: 500;
    display: block;
    margin-bottom: 0.3rem;
  }

  .entry-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-weight: 400;
  }

  @media (max-width: 600px) {
    .entry-link {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 1rem;
    }
  }
</style>
