---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('information', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
const rendered = await Promise.all(sorted.map((p) => p.render()));
---

<BaseLayout title="Information — 풀이">
  <div class="page">
    {sorted.map((post, i) => {
      const { Content } = rendered[i];
      return (
        <article class="entry">
          <div class="col-left">
            <p class="entry-date">
              {post.data.date?.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </p>
            <h2 class="entry-title">{post.data.title}</h2>
          </div>
          <div class="col-right">
            {post.data.description && (
              <p class="entry-desc">{post.data.description}</p>
            )}
            <div class="entry-body">
              <Content />
            </div>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry {
    display: grid;
    grid-template-columns: 1fr 2fr;
    align-items: start;
    padding: 3rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .entry:last-child { border-bottom: none; }

  /* 좌측 */
  .col-left {
    padding-right: 2rem;
  }

  .entry-date {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    margin-bottom: 0.25em;
  }

  .entry-title {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
  }

  /* 우측 */
  .col-right {
    padding-left: 2rem;
  }

  .entry-desc {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    margin-bottom: 1.2em;
  }

  .entry-body {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
  }

  .entry-body :global(p) { margin-bottom: 1.2em; }

  .entry-body :global(h2) {
    font-size: 13px;
    letter-spacing: 0.01em;
    font-weight: 500;
    margin: 1.5em 0 0.5em;
    color: #1a1a1a;
    text-transform: none;
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    padding-left: 1.2em;
    margin-bottom: 1.2em;
  }

  .entry-body :global(li) {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
  }

  @media (max-width: 768px) {
    .entry { grid-template-columns: 1fr; padding: 2rem 1rem; }
    .col-left { padding-right: 0; margin-bottom: 1.5rem; }
    .col-right { padding-left: 0; }
  }
</style>
