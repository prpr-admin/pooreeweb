---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('information', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
const rendered = await Promise.all(sorted.map((p) => p.render()));
---

<BaseLayout title="Information — 풀이">
  <div class="page">
    {sorted.map((post, i) => {
      const { Content } = rendered[i];
      return (
        <article class="entry">
          <div class="col-meta">
            <time class="entry-date">
              {post.data.date?.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </time>
            <h2 class="entry-title">{post.data.title}</h2>
          </div>
          <div class="col-content">
            {post.data.description && (
              <p class="entry-desc">{post.data.description}</p>
            )}
            <div class="entry-body">
              <Content />
            </div>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry {
    display: grid;
    grid-template-columns: 2fr 3fr;
    border-bottom: 0.5px solid var(--color-border);
  }

  .col-meta {
    padding: 2rem 1.5rem;
    border-right: 0.5px solid var(--color-border);
  }

  .entry-date {
    display: block;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    margin-bottom: 0.75rem;
    font-style: normal;
  }

  .entry-title {
    font-size: 13px;
    letter-spacing: 0.03em;
    font-weight: 500;
    line-height: 1.4;
  }

  .col-content {
    padding: 2rem 1.5rem;
  }

  .entry-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .entry-body {
    font-size: 13px;
    line-height: 1.85;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  .entry-body :global(p) {
    margin-bottom: 1.2em;
  }

  .entry-body :global(h2) {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 2em 0 0.75em;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .entry {
      grid-template-columns: 1fr;
    }
    .col-meta {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
      padding: 1.25rem 1rem;
    }
    .col-content {
      padding: 1.25rem 1rem;
    }
  }
</style>
