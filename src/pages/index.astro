---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => b.slug.localeCompare(a.slug));
---

<BaseLayout title="풀이" fullBleed={true}>
  <div class="page">
    <ul class="project-list">
      {projects.map((project) => (
        <li class="project-item">
          <a href={`/projects/${project.slug}`} class="project-link">
            <div class="project-image-wrap">
              {project.data.mainImage ? (
                <img
                  src={project.data.mainImage}
                  alt={project.data.title}
                  class="project-image"
                  loading="lazy"
                />
              ) : (
                <div class="project-image-fallback">
                  <span class="fallback-title">{project.data.title}</span>
                </div>
              )}
            </div>
            <div class="project-caption">
              <span class="project-title">{project.data.title}</span>
              <div class="project-meta">
                {project.data.type && <span class="meta-item">{project.data.type}</span>}
                {project.data.location && <span class="meta-item">{project.data.location}</span>}
                {project.data.year && <span class="meta-item">{project.data.year}</span>}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .project-list { list-style: none; }

  .project-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .project-link {
    display: block;
    color: inherit;
  }

  .project-image-wrap {
    width: 100%;
    aspect-ratio: 1920 / 980;
    overflow: hidden;
    background: #c8c4be;
    transition: opacity 0.2s;
  }

  .project-link:hover .project-image-wrap { opacity: 0.9; }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .project-link:hover .project-image { transform: scale(1.03); }

  .project-image-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background: #c8c4be;
  }

  .fallback-title {
    font-size: 13px;
    letter-spacing: 0.01em;
    color: rgba(0, 0, 0, 0.4);
    font-weight: 400;
  }

  .project-caption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem 1.5rem;
    border-top: 0.5px solid var(--color-border);
  }

  .project-title {
    font-size: 13px;
    letter-spacing: 0.01em;
    font-weight: 400;
    color: #1a1a1a;
  }

  .project-meta {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .meta-item {
    font-size: 13px;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .project-image-wrap {
      aspect-ratio: unset;
      height: 100svh;
    }
    .project-caption { padding: 0.6rem 1rem; flex-wrap: wrap; gap: 0.4rem; }
  }
</style>
