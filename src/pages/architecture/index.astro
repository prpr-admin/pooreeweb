---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('architecture');
const sorted = posts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Architecture — 풀이">
  <div class="page">
    <ul class="entry-list">
      {sorted.map((post) => (
        <li class="entry-item">
          <a href={`/architecture/${post.slug}`} class="entry-link">
            <div class="entry-info">
              <span class="entry-title">{post.data.title}</span>
              <p class="entry-desc">{post.data.description}</p>
            </div>
            <div class="entry-meta">
              {post.data.location && <span class="meta-item">{post.data.location}</span>}
              {post.data.area && <span class="meta-item">{post.data.area}</span>}
              {post.data.status && (
                <span class:list={['meta-item', 'meta-status', `status-${post.data.status}`]}>
                  {post.data.status}
                </span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry-list {
    list-style: none;
  }

  .entry-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .entry-link {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 2rem;
    padding: 1.4rem 1.5rem;
    color: inherit;
    transition: background 0.12s;
  }

  .entry-link:hover {
    background: var(--color-bg-hover);
  }

  .entry-title {
    font-size: 12px;
    letter-spacing: 0.06em;
    font-weight: 500;
    display: block;
    margin-bottom: 0.3rem;
  }

  .entry-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-weight: 400;
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .meta-item {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .meta-status {
    color: var(--color-text-subtle);
  }

  @media (max-width: 600px) {
    .entry-link {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
    }
    .entry-meta { align-items: flex-start; flex-direction: row; gap: 1rem; }
  }
</style>
