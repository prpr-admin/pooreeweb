---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('archives');
const projects = allProjects.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
const rendered = await Promise.all(projects.map((p) => p.render()));
---

<BaseLayout title="Archives — 풀이">
  <div class="page">
    {projects.map((project, i) => {
      const { Content } = rendered[i];
      return (
        <article class="entry">
          <div class="col-left">
            {project.data.thumbnail ? (
              <div class="thumb-wrap">
                <img
                  src={project.data.thumbnail}
                  alt={project.data.title}
                  class="thumb-img"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="thumb-fallback" />
            )}
            <dl class="meta-list">
              {project.data.category && (
                <>
                  <dt class="meta-label">Category</dt>
                  <dd class="meta-value">{project.data.category}</dd>
                </>
              )}
              {project.data.status && (
                <>
                  <dt class="meta-label">Status</dt>
                  <dd class="meta-value">{project.data.status}</dd>
                </>
              )}
              {project.data.year && (
                <>
                  <dt class="meta-label">Year</dt>
                  <dd class="meta-value">{project.data.year}</dd>
                </>
              )}
            </dl>
          </div>

          <div class="col-right">
            <h2 class="entry-title">{project.data.title}</h2>
            {project.data.description && (
              <p class="entry-desc">{project.data.description}</p>
            )}
            <div class="entry-body">
              <Content />
            </div>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry {
    display: grid;
    grid-template-columns: 2fr 3fr;
    border-bottom: 0.5px solid var(--color-border);
  }

  .col-left {
    border-right: 0.5px solid var(--color-border);
  }

  .thumb-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #c8c4be;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-fallback {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #c8c4be;
  }

  .meta-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem 1rem;
    padding: 1.25rem 1.5rem;
  }

  .meta-label {
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    font-weight: 400;
    white-space: nowrap;
    padding-top: 0.1rem;
  }

  .meta-value {
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .col-right {
    padding: 2rem 1.5rem;
  }

  .entry-title {
    font-size: 14px;
    letter-spacing: 0.03em;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .entry-desc {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .entry-body {
    font-size: 13px;
    line-height: 1.85;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  .entry-body :global(p) {
    margin-bottom: 1.2em;
  }

  @media (max-width: 768px) {
    .entry {
      grid-template-columns: 1fr;
    }
    .col-left {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
    }
    .col-right {
      padding: 1.25rem 1rem;
    }
  }
</style>
