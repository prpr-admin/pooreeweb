---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('archives');
const items = allItems.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
const rendered = await Promise.all(items.map((p) => p.render()));
---

<BaseLayout title="Archives — 풀이">
  <div class="page">
    {items.map((item, i) => {
      const { Content } = rendered[i];
      return (
        <article class="entry">
          <div class="col-left">
            <h2 class="entry-title">{item.data.title}</h2>
            <div class="entry-meta">
              {item.data.category && <p class="meta-item">{item.data.category}</p>}
              {item.data.status && <p class="meta-item">{item.data.status}</p>}
              {item.data.year && <p class="meta-item">{item.data.year}</p>}
            </div>
          </div>
          <div class="col-right">
            {item.data.description && (
              <p class="entry-desc">{item.data.description}</p>
            )}
            <div class="entry-body">
              <Content />
            </div>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .entry {
    display: grid;
    grid-template-columns: 1fr 2fr;
    align-items: start;
    padding: 3rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .entry:last-child { border-bottom: none; }

  /* 좌측 */
  .col-left {
    padding-right: 2rem;
  }

  .entry-title {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    margin-bottom: 0.25em;
  }

  .entry-meta {
    margin-top: 0.25em;
  }

  .meta-item {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
  }

  /* 우측 */
  .col-right {
    padding-left: 2rem;
  }

  .entry-desc {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    margin-bottom: 1.2em;
  }

  .entry-body {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
  }

  .entry-body :global(p) { margin-bottom: 1.2em; }

  .entry-body :global(h2) {
    font-size: 13px;
    letter-spacing: 0.01em;
    font-weight: 500;
    margin: 1.5em 0 0.5em;
    color: #1a1a1a;
    text-transform: none;
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    padding-left: 1.2em;
    margin-bottom: 1.2em;
  }

  .entry-body :global(li) {
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #1a1a1a;
  }

  @media (max-width: 768px) {
    .entry { grid-template-columns: 1fr; padding: 2rem 1rem; }
    .col-left { padding-right: 0; margin-bottom: 1.5rem; }
    .col-right { padding-left: 0; }
  }
</style>
