---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('archives');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={`${project.data.title} — 풀이`}>
  <article class="article">

    {project.data.thumbnail && (
      <div class="article-hero">
        <img
          src={project.data.thumbnail}
          alt={project.data.title}
          class="article-hero-image"
        />
      </div>
    )}

    <header class="article-header">
      <h1 class="article-title">{project.data.title}</h1>
      <div class="article-meta">
        {project.data.category && <span class="meta-item">{project.data.category}</span>}
        {project.data.status && <span class="meta-item">{project.data.status}</span>}
        {project.data.year && <span class="meta-item meta-year">{project.data.year}</span>}
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/archives" class="back-link">← All Archives</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .article-hero {
    width: 100%;
    aspect-ratio: 1920 / 980;
    overflow: hidden;
    border-bottom: 0.5px solid var(--color-border);
  }

  .article-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.4rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .article-title {
    font-size: 13px;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .article-meta {
    display: flex;
    gap: 1.4rem;
    align-items: baseline;
  }

  .meta-item {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 400;
    white-space: nowrap;
  }

  .meta-year {
    color: var(--color-text-subtle);
  }

  .article-body {
    padding: 3rem 1.5rem;
    max-width: 640px;
  }

  .article-body :global(p) {
    font-size: 14px;
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.4em;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .article-body :global(h2) {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 2.5em 0 1em;
    color: var(--color-text-muted);
  }

  .article-footer {
    padding: 2rem 1.5rem 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .back-link {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .article-header {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
    }
    .article-body {
      padding: 2rem 1rem;
    }
  }
</style>
