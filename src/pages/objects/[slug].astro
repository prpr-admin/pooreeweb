---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('objects');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} — 풀이`}>
  <article class="article">

    {post.data.cover && (
      <div class="article-hero">
        <img
          src={post.data.cover}
          alt={post.data.title}
          class="article-hero-image"
        />
      </div>
    )}

    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      <div class="article-meta">
        {post.data.material && <span class="meta-item">{post.data.material}</span>}
        {post.data.dimensions && <span class="meta-item">{post.data.dimensions}</span>}
        {post.data.edition && <span class="meta-item meta-edition">{post.data.edition}</span>}
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/objects" class="back-link">← Objects</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .article {
    
  }

  .article-hero {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: 0.5px solid var(--color-border);
  }

  .article-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.4rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .article-title {
    font-size: 13px;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .article-meta {
    display: flex;
    gap: 1.4rem;
    align-items: baseline;
  }

  .meta-item {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 400;
    white-space: nowrap;
  }

  .meta-edition {
    color: var(--color-text-subtle);
  }

  .article-body {
    padding: 3rem 1.5rem;
    max-width: 640px;
  }

  .article-body :global(p) {
    font-size: 14px;
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.4em;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .article-body :global(h2) {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 2.5em 0 1em;
    color: var(--color-text-muted);
  }

  .article-body :global(img) {
    width: 100%;
    height: auto;
    display: block;
    margin: 2rem 0;
  }

  .article-footer {
    padding: 2rem 1.5rem 3rem;
    border-top: 0.5px solid var(--color-border);
  }

  .back-link {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .article-header {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
    }
    .article-body {
      padding: 2rem 1rem;
    }
  }
</style>
