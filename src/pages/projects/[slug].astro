---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, year, program, location, area, status, mainImage, images } = project.data;
---

<BaseLayout title={`${title} — 풀이`}>
  <article class="project-article">

    <!-- 메인 히어로 이미지 -->
    {mainImage && (
      <div class="hero">
        <img src={mainImage} alt={title} class="hero-img" />
      </div>
    )}

    <!-- 제목 헤더 -->
    <header class="project-header">
      <h1 class="project-title">{title}</h1>
    </header>

    <!-- 2컬럼 본문 (1:4 비율) -->
    <div class="project-body">

      <!-- 좌측: 개요 및 설명 텍스트 -->
      <aside class="col-left">
        <dl class="meta-list">
          {program && (
            <>
              <dt class="meta-label">Program</dt>
              <dd class="meta-value">{program}</dd>
            </>
          )}
          {location && (
            <>
              <dt class="meta-label">Location</dt>
              <dd class="meta-value">{location}</dd>
            </>
          )}
          {area && (
            <>
              <dt class="meta-label">Area</dt>
              <dd class="meta-value">{area}</dd>
            </>
          )}
          {year && (
            <>
              <dt class="meta-label">Year</dt>
              <dd class="meta-value">{year}</dd>
            </>
          )}
          {status && (
            <>
              <dt class="meta-label">Status</dt>
              <dd class="meta-value">{status}</dd>
            </>
          )}
        </dl>

        <div class="description-text">
          <Content />
        </div>
      </aside>

      <!-- 우측: 이미지 갤러리 -->
      <div class="col-right">
        {images.length > 0 ? (
          images.map((img) => (
            <div class="gallery-item">
              <img src={img} alt="" class="gallery-img" loading="lazy" />
            </div>
          ))
        ) : (
          <div class="gallery-empty" />
        )}
      </div>
    </div>

    <!-- 뒤로 가기 -->
    <footer class="project-footer">
      <a href="/projects" class="back-link">← All Projects</a>
    </footer>

  </article>
</BaseLayout>

<style>
  .project-article {
    width: 100%;
  }

  /* 히어로 이미지 */
  .hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #c8c4be;
    border-bottom: 0.5px solid var(--color-border);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 제목 헤더 */
  .project-header {
    padding: 1.4rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .project-title {
    font-size: 13px;
    letter-spacing: 0.04em;
    font-weight: 500;
    line-height: 1.4;
  }

  /* 2컬럼 레이아웃 (1:4) */
  .project-body {
    display: grid;
    grid-template-columns: 2fr 3fr;
    border-bottom: 0.5px solid var(--color-border);
    min-height: 50vh;
  }

  /* 좌측 컬럼 */
  .col-left {
    padding: 2rem 1.5rem;
    border-right: 0.5px solid var(--color-border);
  }

  .meta-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem 1rem;
    margin-bottom: 2.5rem;
  }

  .meta-label {
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    font-weight: 400;
    white-space: nowrap;
    padding-top: 0.1rem;
  }

  .meta-value {
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .description-text {
    font-size: 11px;
    line-height: 1.9;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .description-text :global(p) {
    margin-bottom: 1.2em;
  }

  /* 우측 컬럼 */
  .col-right {
    display: flex;
    flex-direction: column;
  }

  .gallery-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .gallery-item:last-child {
    border-bottom: none;
  }

  .gallery-img {
    width: 100%;
    display: block;
  }

  .gallery-empty {
    flex: 1;
    background: #f5f4f2;
    min-height: 300px;
  }

  /* 푸터 */
  .project-footer {
    padding: 1.5rem;
    border-top: 0.5px solid var(--color-border);
  }

  .back-link {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  /* 모바일 */
  @media (max-width: 768px) {
    .project-body {
      grid-template-columns: 1fr;
    }

    .col-left {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
    }
  }
</style>
