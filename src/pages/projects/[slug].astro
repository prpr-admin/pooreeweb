---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, year, type, program, location, area, status, description, mainImage, images } = project.data;
---

<BaseLayout title={`${title} — 풀이`}>
  <article class="project-article">

    <!-- 메인 히어로 이미지 -->
    {mainImage && (
      <div class="hero">
        <img src={mainImage} alt={title} class="hero-img" />
      </div>
    )}

    <!-- 2컬럼 본문 (1:2 비율) -->
    <div class="project-body">

      <!-- 좌측: 제목 + 메타 개요 (sticky) -->
      <aside class="col-left">
        <h1 class="project-title">{title}</h1>

        <dl class="meta-list">
          {type && (
            <>
              <dt class="meta-label">Type</dt>
              <dd class="meta-value">{type}</dd>
            </>
          )}
          {year && (
            <>
              <dt class="meta-label">Year</dt>
              <dd class="meta-value">{year}</dd>
            </>
          )}
          {program && (
            <>
              <dt class="meta-label">Program</dt>
              <dd class="meta-value">{program}</dd>
            </>
          )}
          {area && (
            <>
              <dt class="meta-label">Area</dt>
              <dd class="meta-value">{area}</dd>
            </>
          )}
          {location && (
            <>
              <dt class="meta-label">Location</dt>
              <dd class="meta-value">{location}</dd>
            </>
          )}
          {status && (
            <>
              <dt class="meta-label">Status</dt>
              <dd class="meta-value">{status}</dd>
            </>
          )}
        </dl>

        <a href="/projects" class="back-link">←</a>
      </aside>

      <!-- 우측: description + 이미지 (스크롤) -->
      <div class="col-right">
        <div class="description-text">
          <Content />
        </div>

        {images.length > 0 && images.map((img) => (
          <div class="gallery-item">
            <img src={img} alt="" class="gallery-img" loading="lazy" />
          </div>
        ))}
      </div>
    </div>

  </article>
</BaseLayout>

<style>
  .project-article {
    width: 100%;
  }

  /* 히어로 이미지 */
  .hero {
    width: 100%;
    aspect-ratio: 1920 / 980;
    overflow: hidden;
    background: #c8c4be;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 2컬럼 레이아웃 (1:2) */
  .project-body {
    display: grid;
    grid-template-columns: 1fr 2fr;
    align-items: start;
  }

  /* 좌측: sticky */
  .col-left {
    position: sticky;
    top: 0;
    padding: 3rem 2rem 3rem 1.5rem;
  }

  .project-title {
    font-size: 13px;
    letter-spacing: 0.03em;
    font-weight: 500;
    line-height: 1.5;
    color: #1a1a1a;
    margin-bottom: 2.5rem;
  }

  .meta-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1.5rem;
    margin-bottom: 3rem;
    line-height: 1.9;
  }

  .meta-label {
    font-size: 13px;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
    white-space: nowrap;
  }

  .meta-value {
    font-size: 13px;
    letter-spacing: 0.01em;
    color: #1a1a1a;
    font-weight: 400;
  }

  .back-link {
    font-size: 13px;
    color: #1a1a1a;
    transition: opacity 0.15s;
  }

  .back-link:hover {
    opacity: 0.5;
  }

  /* 우측: description + 이미지 */
  .col-right {
    padding: 3rem 1.5rem 3rem 2rem;
  }

  .description-text {
    font-size: 13px;
    line-height: 1.9;
    color: #1a1a1a;
    letter-spacing: 0.01em;
    margin-bottom: 3rem;
  }

  .description-text :global(p) {
    margin-bottom: 1.2em;
  }

  .description-text :global(h2) {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 2em 0 0.75em;
    color: #1a1a1a;
  }

  .gallery-item {
    margin-bottom: 1.5rem;
  }

  .gallery-item:last-child {
    margin-bottom: 0;
  }

  .gallery-img {
    width: 100%;
    display: block;
  }

  /* 모바일 */
  @media (max-width: 768px) {
    .project-body {
      grid-template-columns: 1fr;
    }

    .col-left {
      position: static;
      padding: 2rem 1rem 1.5rem;
    }

    .col-right {
      padding: 0 1rem 2rem;
    }
  }
</style>
