---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => b.slug.localeCompare(a.slug));
---

<BaseLayout title="Projects — 풀이">
  <div class="page">
    <ul class="project-list">
      {projects.map((project) => (
        <li class="project-item">
          <a href={`/projects/${project.slug}`} class="project-link">
            <div class="project-image-wrap">
              {project.data.mainImage ? (
                <img
                  src={project.data.mainImage}
                  alt={project.data.title}
                  class="project-image"
                  loading="lazy"
                />
              ) : (
                <div class="project-image-fallback">
                  <span class="fallback-title">{project.data.title}</span>
                </div>
              )}
            </div>
            <div class="project-caption">
              <span class="project-title">{project.data.title}</span>
              <div class="project-meta">
                {project.data.program && <span class="meta-item">{project.data.program}</span>}
                {project.data.location && <span class="meta-item">{project.data.location}</span>}
                {project.data.year && <span class="meta-item meta-year">{project.data.year}</span>}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page { width: 100%; }

  .project-list {
    list-style: none;
  }

  .project-item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .project-link {
    display: block;
    color: inherit;
  }

  .project-image-wrap {
    width: 100%;
    aspect-ratio: 1920 / 980;
    overflow: hidden;
    background: #c8c4be;
    transition: opacity 0.2s;
  }

  .project-link:hover .project-image-wrap {
    opacity: 0.9;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .project-link:hover .project-image {
    transform: scale(1.03);
  }

  .project-image-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background: #c8c4be;
  }

  .fallback-title {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(0, 0, 0, 0.35);
    font-weight: 500;
  }

  .project-caption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 1.5rem;
    border-top: 0.5px solid var(--color-border);
  }

  .project-title {
    font-size: 12px;
    letter-spacing: 0.03em;
    font-weight: 500;
  }

  .project-meta {
    display: flex;
    align-items: baseline;
    gap: 1.4rem;
  }

  .meta-item {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 400;
    white-space: nowrap;
  }

  .meta-year {
    color: var(--color-text-subtle);
  }

  @media (max-width: 768px) {
    .project-image-wrap {
      aspect-ratio: 1 / 1;
    }
    .project-caption {
      padding: 0.5rem 1rem;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
  }
</style>
